# Optional. If unset, the app uses a built-in mock correction/lesson generator.
OPENAI_API_KEY=

# Optional model override (default: gpt-4o-mini).
OPENAI_MODEL=gpt-4o-mini

# Optional. Supabase is wired in but the app runs without it (localStorage fallback).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Optional. Only needed to (re)generate topic illustrations via the
# manual script `npm run visuals:generate`. Never used by the running
# app / frontend. Put the real value in .env.local (gitignored).
GOOGLE_AI_STUDIO_API_KEY=
